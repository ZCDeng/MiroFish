# LLM API配置（统一 OpenAI SDK 协议）
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# 后端端口（与 docker-compose.yml 保持一致）
FLASK_PORT=5002

# Graphiti / Neo4j 配置
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Graphiti 使用的 OpenAI 兼容密钥（可与 LLM_API_KEY 相同）
OPENAI_API_KEY=your_api_key_here

GRAPHITI_API_KEY=${LLM_API_KEY}
GRAPHITI_BASE_URL=${LLM_BASE_URL}
GRAPHITI_MODEL_NAME=${LLM_MODEL_NAME}
GRAPHITI_SMALL_MODEL_NAME=${GRAPHITI_MODEL_NAME}
GRAPHITI_REQUEST_TIMEOUT=30
GRAPHITI_REQUEST_RETRIES=1
GRAPHITI_EPISODE_TIMEOUT=25
GRAPHITI_SEMAPHORE_LIMIT=5
GRAPHITI_BUILD_TIMEOUT=120
GRAPHITI_BUILD_TIMEOUT_CAP=1800
GRAPHITI_BATCH_SIZE=1
GRAPHITI_CHUNK_MAX_CHARS=1200
GRAPHITI_MAX_CHUNKS=10
GRAPHITI_ONTOLOGY_CHUNK_THRESHOLD=40
GRAPHITI_MAX_ENTITY_TYPES=6
GRAPHITI_MAX_ENTITY_ATTRIBUTES=3
GRAPHITI_MAX_TOKENS=1024
