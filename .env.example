# LLM API配置（统一 OpenAI SDK 协议）
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 推荐：qwen3-14b（阿里云，性价比最优，比 qwen3.6-plus 低 72% 成本）
# 备选：qwen3.6-plus（更强但更贵）、gpt-4o-mini（OpenAI）
LLM_MODEL_NAME=qwen3-14b

# 后端端口（与 docker-compose.yml 保持一致）
FLASK_PORT=5002

# Graphiti / Neo4j 配置
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Graphiti 使用的 OpenAI 兼容密钥（可与 LLM_API_KEY 相同）
OPENAI_API_KEY=your_api_key_here

GRAPHITI_API_KEY=${LLM_API_KEY}
GRAPHITI_BASE_URL=${LLM_BASE_URL}
GRAPHITI_MODEL_NAME=${LLM_MODEL_NAME}
# 小模型用于低复杂度实体任务，可设为比主模型更小的版本
GRAPHITI_SMALL_MODEL_NAME=qwen3-1.7b
GRAPHITI_REQUEST_TIMEOUT=180
GRAPHITI_REQUEST_RETRIES=0
GRAPHITI_EPISODE_TIMEOUT=480
GRAPHITI_SEMAPHORE_LIMIT=5
GRAPHITI_BUILD_TIMEOUT=540
GRAPHITI_BUILD_TIMEOUT_CAP=7200
GRAPHITI_BATCH_SIZE=1
GRAPHITI_CHUNK_MAX_CHARS=1200
GRAPHITI_MAX_CHUNKS=5
GRAPHITI_ONTOLOGY_CHUNK_THRESHOLD=40
GRAPHITI_MAX_ENTITY_TYPES=6
GRAPHITI_MAX_ENTITY_ATTRIBUTES=3
GRAPHITI_MAX_TOKENS=8192
